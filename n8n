      "parameters": {
        "jsCode": "const incomingCode = String($json.error_code || '');\nlet errorCode = incomingCode || 'DEAL_CONTEXT_ANALYSIS_ERROR';\nlet errorMessage = 'Не удалось сформировать справку для сделки.';\n\nif (errorCode === 'ONE_C_PROTOCOLS_ERROR') {\n  errorMessage = 'Не удалось получить историю пациента из 1С.';\n} else if (errorCode === 'PATIENT_OR_PROTOCOLS_NOT_FOUND') {\n  errorMessage = 'Пациент или доступные протоколы не найдены.';\n} else if (errorCode === 'MODEL_JSON_PARSE_ERROR') {\n  errorMessage = 'Не удалось сформировать справку для сделки.';\n} else if ($json.message) {\n  errorMessage = String($json.message);\n}\n\nreturn [{\n  json: {\n    spreadsheet_id: $json.spreadsheet_id,\n    sheet_name: $json.sheet_name,\n    row_number: $json.row_number,\n    deal_key: $json.deal_key,\n    request_id: $json.request_id,\n    batch_id: $json.batch_id,\n    batch_size: $json.batch_size,\n    sheet_columns: $json.sheet_columns,\n    batch_update_url: $json.batch_update_url,\n    ok: false,\n    final_update: {\n      'AI статус': 'error',\n      'AI request_id': $json.request_id,\n      'AI updated_at': new Date().toISOString(),\n      'Ошибка': `${errorCode}: ${errorMessage}`\n    }\n  }\n}];"
