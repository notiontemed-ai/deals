        "jsCode": "const fields = [\n  'interaction_history',\n  'last_visit_context',\n  'booking_execution_context',\n  'admin_context',\n  'communication_context'\n];\n\ntry {\n  let raw =\n    $json.message?.content ??\n    $json.text ??\n    $json.content ??\n    $json.output ??\n    $json.response ??\n    '';\n\n  if (typeof raw !== 'string') {\n    raw = JSON.stringify(raw);\n  }\n\n  raw = raw\n    .trim()\n    .replace(/^```json\\s*/i, '')\n    .replace(/^```\\s*/, '')\n    .replace(/```$/, '')\n    .trim();\n\n  const obj = JSON.parse(raw);\n\n  if (!obj || Array.isArray(obj) || typeof obj !== 'object') {\n    throw new Error('OpenAI returned non-object JSON');\n  }\n\n  const summary = {};\n\n  for (const f of fields) {\n    summary[f] = typeof obj[f] === 'string' ? obj[f].trim() : '';\n  }\n\n  return [{\n    json: {\n      ...$('Prepare deal context prompt v3').item.json,\n      summary\n    }\n  }];\n} catch (error) {\n  return [{\n    json: {\n      ...$('Prepare deal context prompt v3').item.json,\n      ok: false,\n      status: 'analysis_error',\n      error_code: 'MODEL_JSON_PARSE_ERROR',\n      message: 'Не удалось сформировать справку для сделки.',\n      http_status: 502\n    }\n  }];\n}"
