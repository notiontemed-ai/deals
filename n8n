        "jsCode": "function arr(v) {\n  return !v ? [] : (Array.isArray(v) ? v : [v]);\n}\n\nfunction val(v) {\n  if (v == null) return '';\n  if (typeof v === 'object') return String(v._ ?? v.Value ?? v.value ?? v.Text ?? '');\n  return String(v);\n}\n\nfunction stripHtml(s) {\n  return val(s)\n    .replace(/<[^>]*>/g, ' ')\n    .replace(/\\r/g, '\\n')\n    .replace(/[ \\t]+/g, ' ')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .trim();\n}\n\nfunction norm(s) {\n  return stripHtml(s)\n    .replace(/\\u00a0/g, ' ')\n    .toLowerCase()\n    .replace(/ё/g, 'е');\n}\n\nconst excludedParamNames = [\n  'пациент', 'пациент сокр', 'дата рождения', 'номер карты', '№ карты',\n  'код пациента', 'телефон', 'адрес', 'почта', 'email', 'e-mail',\n  'паспорт', 'снилс', 'инн', 'полис', 'представитель', 'контактное лицо', 'родственник'\n];\n\nconst full = $json.patient_full_name || '';\n\nfunction clean(s) {\n  let x = stripHtml(s);\n  if (full) {\n    x = x.replace(new RegExp(full.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&'), 'gi'), '[ПАЦИЕНТ]');\n  }\n  return x\n    .replace(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}/gi, '[EMAIL УДАЛЁН]')\n    .replace(/(?:\\+7|8)[\\s\\-()]*\\d{3}[\\s\\-()]*\\d{3}[\\s\\-]*\\d{2}[\\s\\-]*\\d{2}/g, '[ТЕЛЕФОН УДАЛЁН]')\n    .replace(/\\d{3}-\\d{3}-\\d{3}\\s?\\d{2}/g, '[СНИЛС УДАЛЁН]')\n    .replace(/\\b\\d{4}\\s?\\d{6}\\b/g, '[ПАСПОРТ УДАЛЁН]')\n    .trim();\n}\n\nfunction params(p) {\n  return arr(p.Params?.Param ?? p.Params);\n}\n\nfunction iso(d) {\n  const s = val(d);\n  const m = s.match(/^(\\d{4}-\\d{2}-\\d{2})|^(\\d{2})\\.(\\d{2})\\.(\\d{4})/);\n  return m ? (m[1] || `${m[4]}-${m[3]}-${m[2]}`) : '';\n}\n\nconst sanitized_protocols = $json.selected_protocols\n  .map(p => ({\n    date: iso(p.Date),\n    type: val(p.Type),\n    doctor: clean(p.Employee?.FullName),\n    clinic: clean(p.Clinic?.Name),\n    params: params(p)\n      .map(prm => ({\n        name: clean(prm.Name ?? prm.name),\n        value: clean(prm.Value ?? prm.value ?? prm.Text)\n      }))\n      .filter(x =>\n        x.name &&\n        x.value &&\n        !excludedParamNames.some(b => norm(x.name).includes(b))\n      )\n  }))\n  .filter(p => p.params.length);\n\nconst deal_context = {\n  deal_key: $json.deal_key,\n  row_number: $json.row_number,\n  patient_code: $json.patient_code,\n  patient_name: $json.patient_name,\n  branch: $json.branch,\n  deal_amount: $json.deal_amount,\n  first_plan_date: $json.first_plan_date,\n  doctor: $json.doctor,\n  uids: $json.uids,\n  appointment_composition: $json.appointment_composition,\n  nearest_requests: $json.nearest_requests,\n  deal_description: $json.deal_description,\n  booking_execution_context: $json.booking_execution_context\n};\n\nreturn [{\n  json: {\n    spreadsheet_id: $json.spreadsheet_id,\n    sheet_name: $json.sheet_name,\n    row_number: $json.row_number,\n    deal_key: $json.deal_key,\n    request_id: $json.request_id,\n    batch_id: $json.batch_id,\n    batch_size: $json.batch_size,\n    sheet_columns: $json.sheet_columns,\n    batch_update_url: $json.batch_update_url,\n    client_context: $json.client_context || {},\n    client_context_error: $json.client_context_error || '',\n    patient_age: $json.patient.age,\n    patient: $json.patient,\n    meta: {\n      period_from: $json.period_from,\n      period_to: $json.period_to,\n      protocols_found: $json.protocols_found,\n      protocols_used: $json.protocols_used,\n      history_truncated: $json.history_truncated\n    },\n    visits: $json.visits,\n    deal_context,\n    sanitized_protocols\n  }\n}];"
