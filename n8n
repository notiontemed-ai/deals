    {
      "parameters": {
        "jsCode": "const results = $input.all().map(item => item.json);\n\nif (!results.length) {\n  throw new Error('Loop completed without result items.');\n}\n\nconst first = results[0];\nconst sheetColumns = first.sheet_columns || {};\nconst requiredBase = ['AI статус', 'AI request_id', 'AI updated_at', 'Ошибка'];\nconst missing = requiredBase.filter(name => !sheetColumns[name]);\nif (missing.length) {\n  throw new Error(`Missing columns for final batch update: ${missing.join(', ')}`);\n}\n\nfunction quoteSheet(name) {\n  return `'${String(name).replace(/'/g, \"''\")}'`;\n}\n\nconst sheet = quoteSheet(first.sheet_name);\nconst data = [];\n\nfor (const result of results) {\n  if (result.spreadsheet_id !== first.spreadsheet_id || result.sheet_name !== first.sheet_name) {\n    throw new Error('Final result items belong to different spreadsheets or sheets.');\n  }\n\n  const row = Number(result.row_number);\n  if (!Number.isInteger(row) || row < 2) {\n    throw new Error(`Invalid row_number in final item: ${result.row_number}`);\n  }\n\n  for (const [columnName, value] of Object.entries(result.final_update || {})) {\n    const column = sheetColumns[columnName];\n    if (!column) {\n      throw new Error(`Column not found in header map: ${columnName}`);\n    }\n\n    data.push({\n      range: `${sheet}!${column}${row}`,\n      majorDimension: 'ROWS',\n      values: [[value ?? '']]\n    });\n  }\n}\n\nreturn [{\n  json: {\n    ok: true,\n    batch_id: first.batch_id,\n    batch_size: results.length,\n    spreadsheet_id: first.spreadsheet_id,\n    sheet_name: first.sheet_name,\n    batch_update_url: first.batch_update_url,\n    done_count: results.filter(x => x.ok === true).length,\n    error_count: results.filter(x => x.ok !== true).length,\n    final_batch_body: {\n      valueInputOption: 'RAW',\n      data\n    }\n  }\n}];"
