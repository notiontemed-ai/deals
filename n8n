      "parameters": {
        "jsCode": "if ($json.ok === false) {\n  return [{ json: $json }];\n}\n\nconst summary = $json.summary || {};\nconst parts = [];\n\nparts.push('КРАТКАЯ СПРАВКА ДЛЯ СДЕЛКИ');\n\nif ((summary.interaction_history || '').trim()) {\n  parts.push('История взаимодействия:\\n' + summary.interaction_history.trim());\n}\n\nif ((summary.last_visit_context || '').trim()) {\n  parts.push('Последний прием:\\n' + summary.last_visit_context.trim());\n}\n\nif ((summary.booking_execution_context || '').trim()) {\n  parts.push('Запись/исполнение:\\n' + summary.booking_execution_context.trim());\n}\n\nif ((summary.admin_context || '').trim()) {\n  parts.push('Комментарий администратора:\\n' + summary.admin_context.trim());\n}\n\nif ((summary.communication_context || '').trim()) {\n  parts.push('Особенности коммуникации:\\n' + summary.communication_context.trim());\n}\n\nconst summaryText = parts.join('\\n\\n');\n\nreturn [{\n  json: {\n    spreadsheet_id: $json.spreadsheet_id,\n    sheet_name: $json.sheet_name,\n    row_number: $json.row_number,\n    deal_key: $json.deal_key,\n    request_id: $json.request_id,\n    batch_id: $json.batch_id,\n    batch_size: $json.batch_size,\n    sheet_columns: $json.sheet_columns,\n    batch_update_url: $json.batch_update_url,\n    client_context: $json.client_context || {},\n    client_context_error: $json.client_context_error || '',\n    ok: true,\n    status: 'done',\n    source: 'deal_patient_context_v2',\n    summary,\n    summary_text: summaryText\n  }\n}];"
